---
import type { FeaturedProject, GitHubRepo } from "../data/types";

interface Props {
  project: FeaturedProject;
  relatedRepos?: GitHubRepo[];
}

const { project, relatedRepos = [] } = Astro.props;
---

<article class="surface-card h-full">
  <div class="flex flex-wrap items-center gap-3">
    <h3 class="text-lg font-semibold tracking-tight text-[var(--text-main)]">{project.title}</h3>
    <span class="status-badge">{project.status}</span>
    <span class="subtle-badge">{project.type}</span>
  </div>
  <p class="mt-4 text-sm leading-7 text-[var(--text-soft)]">{project.summaryZh}</p>
  {
    project.summaryEn && (
      <p class="mt-3 text-xs leading-6 text-[var(--text-faint)]">{project.summaryEn}</p>
    )
  }
  <div class="mt-5 flex flex-wrap gap-2">
    {
      project.tags.map((tag) => (
        <span class="chip">{tag}</span>
      ))
    }
  </div>
  {
    relatedRepos.length > 0 && (
      <div class="mt-6 space-y-2">
        <p class="text-xs uppercase tracking-[0.18em] text-[var(--text-faint)]">Related repos</p>
        <div class="flex flex-wrap gap-2">
          {relatedRepos.slice(0, 3).map((repo) => (
            <a
              class="inline-flex items-center gap-2 rounded-full border border-[var(--line)] px-3 py-1.5 text-xs text-[var(--text-soft)] transition hover:border-[var(--line-strong)] hover:text-[var(--text-main)]"
              href={repo.html_url}
              rel="noreferrer"
              target="_blank"
            >
              <span>{repo.name}</span>
              {repo.fork && <span class="fork-chip">Fork / Curation</span>}
            </a>
          ))}
        </div>
      </div>
    )
  }
  {
    project.links && project.links.length > 0 ? (
      <div class="mt-6 flex flex-wrap gap-3">
        {project.links.map((link) => (
          <a
            class="inline-flex items-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface-muted)] px-4 py-2 text-sm font-medium text-[var(--text-main)] transition hover:border-[var(--line-strong)]"
            href={link.href}
            rel="noreferrer"
            target="_blank"
          >
            <span>{link.label}</span>
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    ) : (
      project.note && <p class="mt-6 text-xs leading-6 text-[var(--text-faint)]">{project.note}</p>
    )
  }
</article>
